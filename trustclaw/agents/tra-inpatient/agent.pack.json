{
  "id": "tra-inpatient",
  "version": "1.0.0",
  "displayName": {
    "zh-CN": "住院医保结算",
    "en": "Inpatient Insurance Settlement"
  },
  "domain": [
    "inpatient",
    "insurance",
    "settlement"
  ],
  "openclaw": {
    "agentId": "tra-inpatient"
  },
  "tools": {
    "read": "trustclaw_tra_query",
    "write": "trustclaw_tra_write"
  },
  "prompts": {
    "system": "prompts/system.v1.md",
    "text2sql": "prompts/text2sql.v1.md",
    "personalWrite": "prompts/personal-write-sql.v1.md"
  },
  "data": {
    "readTables": [
      "clinical_diagnoses",
      "lab_test_results",
      "body_anthropometrics",
      "medication_history",
      "user_profile",
      "data_source_registry",
      "nrdl_drug_registry",
      "nrdl_payment_rules"
    ],
    "writeTables": [
      "lab_test_results"
    ]
  },
  "rules": {
    "engine": "none"
  },
  "pipeline": {
    "stages": [
      "TEXT2SQL_GEN",
      "DB_QUERY",
      "RULE_EVAL",
      "AGENT_DECISION",
      "LEDGER_COMMIT"
    ],
    "decisionBuilder": "pass-through"
  },
  "consent": {
    "read": {
      "allowAlways": true
    },
    "write": {
      "allowAlways": false
    }
  },
  "audit": {
    "businessComponent": "TRA.Agent.Inpatient",
    "decisionComponent": "Agent.InpatientDecision",
    "ruleEvalComponent": "AgentRuntime.ExecRule"
  }
}
