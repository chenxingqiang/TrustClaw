{
  "id": "tra-drg",
  "version": "1.0.0",
  "displayName": {
    "zh-CN": "DRG/DIP 分组与结算",
    "en": "DRG/DIP Grouping & Settlement"
  },
  "domain": [
    "drg",
    "dip",
    "insurance"
  ],
  "openclaw": {
    "agentId": "tra-drg"
  },
  "tools": {
    "read": "trustclaw_tra_query"
  },
  "prompts": {
    "system": "prompts/system.v1.md",
    "text2sql": "prompts/text2sql.v1.md"
  },
  "data": {
    "readTables": [
      "clinical_diagnoses",
      "lab_test_results",
      "body_anthropometrics",
      "user_profile",
      "data_source_registry",
      "nrdl_drug_registry",
      "nrdl_payment_rules",
      "v_glp1_nrdl_check_snapshot"
    ],
    "snapshotView": "v_glp1_nrdl_check_snapshot"
  },
  "rules": {
    "engine": "none"
  },
  "pipeline": {
    "stages": [
      "TEXT2SQL_GEN",
      "DB_QUERY",
      "RULE_EVAL",
      "AGENT_DECISION",
      "LEDGER_COMMIT"
    ],
    "decisionBuilder": "pass-through"
  },
  "consent": {
    "read": {
      "allowAlways": true
    }
  },
  "audit": {
    "businessComponent": "TRA.Agent.DRG",
    "decisionComponent": "Agent.DRGDecision",
    "ruleEvalComponent": "AgentRuntime.ExecRule"
  }
}
